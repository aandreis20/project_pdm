<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RecipesApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RecipesApp.Views"
    Title="RecipesApp"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    
    Shell.TabBarBackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLowest}, Dark={StaticResource Gray900}}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
    Shell.TabBarTitleColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray600}}">

    <ShellContent
        Route="LoginPage"
        Shell.TabBarIsVisible="False"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <TabBar Route="AppTabs">

        <ShellContent
            Title="Recipes"
            ContentTemplate="{DataTemplate views:RecipesPage}"
            Route="RecipesPage">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#xE561;" FontFamily="MaterialIcons" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="Planner"
            ContentTemplate="{DataTemplate views:PlannerPage}"
            Route="PlannerPage">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#xEBCC;" FontFamily="MaterialIcons" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="Profile"
            ContentTemplate="{DataTemplate views:ProfilePage}"
            Route="ProfilePage">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#xE7FD;" FontFamily="MaterialIcons" />
            </ShellContent.Icon>
        </ShellContent>

    </TabBar>

</Shell>