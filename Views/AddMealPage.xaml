<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RecipesApp.Views.AddMealPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:RecipesApp.ViewModels"
    Title="Add Meal"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <VerticalStackLayout Padding="16" Spacing="12">

        <Label Text="Date" FontAttributes="Bold" />
        <DatePicker Date="{Binding SelectedDate}" />

        <Label Text="Meal Type" FontAttributes="Bold" />
        <Picker ItemsSource="{Binding MealTypes}" SelectedItem="{Binding SelectedMealType}" />

        <Label Text="Recipe" FontAttributes="Bold" />
        <Picker ItemsSource="{Binding Recipes}" ItemDisplayBinding="{Binding Title}" SelectedItem="{Binding SelectedRecipe}" />

        <HorizontalStackLayout Spacing="12" HorizontalOptions="End">
            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark=White}"
                    FontAttributes="Bold" />

            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    FontAttributes="Bold"
                    Padding="12,8"
                    CornerRadius="6" />
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>