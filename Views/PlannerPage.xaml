<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RecipesApp.Views.PlannerPage"
    x:Name="PlannerPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:RecipesApp.ViewModels"
    xmlns:models="clr-namespace:RecipesApp.Data"
    Title="Meal Planner"
    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#121212}">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Date Navigator -->
        <Border
            Grid.Row="0"
            Margin="16,16,16,8"
            Padding="12"
            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLowest}, Dark=#1E1E1E}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 12">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto">

                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        BackgroundColor="Transparent"
                        WidthRequest="40" HeightRequest="40"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PreviousDayCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="&#xE5C4;"
                           FontFamily="MaterialIcons"
                           FontSize="22"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                </Border>

                <VerticalStackLayout
                    Grid.Column="1"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="{Binding SelectedDate, StringFormat='{0:dddd}'}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark=White}" />
                    <Label
                        FontSize="13"
                        HorizontalOptions="Center"
                        Text="{Binding SelectedDate, StringFormat='{0:MMMM dd, yyyy}'}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark=#AAA}" />
                </VerticalStackLayout>

                <Border Grid.Column="2"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        BackgroundColor="Transparent"
                        WidthRequest="40" HeightRequest="40"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NextDayCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="&#xE5C8;"
                           FontFamily="MaterialIcons"
                           FontSize="22"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                </Border>

            </Grid>
        </Border>

        <!-- Daily Totals Summary -->
        <Border
            Grid.Row="1"
            Margin="16,0,16,8"
            Padding="16,12"
            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLowest}, Dark=#1E1E1E}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 12">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto,*">

                <!-- Prep Time -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                    <Label Text="&#xE422;"
                           FontFamily="MaterialIcons"
                           FontSize="20"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                    <Label Text="{Binding TotalPrepTime, StringFormat='{0} min'}"
                           FontAttributes="Bold"
                           FontSize="15"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark=White}" />
                    <Label Text="Total Prep"
                           FontSize="11"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark=#AAA}" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView Grid.Column="1"
                         WidthRequest="1"
                         HeightRequest="40"
                         VerticalOptions="Center"
                         Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark=#333}" />

                <!-- Calories -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                    <Label Text="&#xE253;"
                           FontFamily="MaterialIcons"
                           FontSize="20"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                    <Label Text="{Binding TotalCalories, StringFormat='{0} kcal'}"
                           FontAttributes="Bold"
                           FontSize="15"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark=White}" />
                    <Label Text="Total Calories"
                           FontSize="11"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark=#AAA}" />
                </VerticalStackLayout>

            </Grid>
        </Border>

        <!-- Loading indicator -->
        <ActivityIndicator
            Grid.Row="2"
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

        <!-- Sections list -->
        <ScrollView Grid.Row="3" Margin="16,0">
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Sections}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:MealSection">
                        <VerticalStackLayout Margin="0,0,0,16">

                            <!-- Section Header -->
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Margin="4,8,0,8"
                                Text="{Binding MealType}"
                                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                            <!-- Meal cards -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Meals}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:MealPlan">
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="12"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLowest}, Dark=#1E1E1E}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10">
                                            <Border.Shadow>
                                                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                                            </Border.Shadow>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference PlannerPageRoot}, Path=BindingContext.OpenRecipeCommand}"
                                                    CommandParameter="{Binding Recipe}" />
                                            </Border.GestureRecognizers>

                                            <Grid ColumnDefinitions="56,*,Auto">

                                                <!-- Recipe image -->
                                                <Border
                                                    Grid.Column="0"
                                                    Padding="0"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8"
                                                    HeightRequest="56"
                                                    WidthRequest="56">
                                                    <Image
                                                        Aspect="AspectFill"
                                                        HeightRequest="56"
                                                        Source="{Binding Recipe.ImageUrl}"
                                                        WidthRequest="56" />
                                                </Border>

                                                <!-- Title + description -->
                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    VerticalOptions="Center">
                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="14"
                                                        Text="{Binding Recipe.Title}"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark=White}" />
                                                    <Label
                                                        FontSize="12"
                                                        MaxLines="2"
                                                        Text="{Binding Recipe.Description}"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark=#AAA}" />
                                                </VerticalStackLayout>

                                                <!-- Delete button -->
                                                <Border
                                                    Grid.Column="2"
                                                    StrokeShape="RoundRectangle 8"
                                                    StrokeThickness="0"
                                                    BackgroundColor="Transparent"
                                                    WidthRequest="36" HeightRequest="36"
                                                    VerticalOptions="Center">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference PlannerPageRoot}, Path=BindingContext.DeleteMealCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Border.GestureRecognizers>
                                                    <Label Text="&#xE872;"
                                                           FontFamily="MaterialIcons"
                                                           FontSize="20"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"
                                                           TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark=#AAA}" />
                                                </Border>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>

        <!-- FAB -->
        <Button
            Grid.Row="3"
            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
            CornerRadius="28"
            FontSize="24"
            HeightRequest="56"
            HorizontalOptions="End"
            Margin="0,0,24,24"
            Text="+"
            TextColor="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}"
            VerticalOptions="End"
            WidthRequest="56"
            Clicked="OnAddMealClicked" />

    </Grid>
</ContentPage>