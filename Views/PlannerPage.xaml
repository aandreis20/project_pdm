<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RecipesApp.Views.PlannerPage"
    x:Name="PlannerPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:RecipesApp.ViewModels"
    xmlns:models="clr-namespace:RecipesApp.Data"
    Title="Meal Planner"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Date Navigator -->
        <Frame
            Grid.Row="0"
            Margin="16,16,16,8"
            Padding="12"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
            BorderColor="Transparent"
            CornerRadius="12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button
                    Grid.Column="0"
                    Command="{Binding PreviousDayCommand}"
                    Text="&lt;"
                    BackgroundColor="Transparent"
                    TextColor="#FF6B35"
                    FontAttributes="Bold"
                    FontSize="18"
                    WidthRequest="36"
                    HeightRequest="36" />

                <VerticalStackLayout
                    Grid.Column="1"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="{Binding SelectedDate, StringFormat='{0:dddd}'}"
                        TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                    <Label
                        FontSize="13"
                        HorizontalOptions="Center"
                        Text="{Binding SelectedDate, StringFormat='{0:MMMM dd, yyyy}'}"
                        TextColor="{AppThemeBinding Light=#888, Dark=#AAA}" />
                </VerticalStackLayout>

                <Button
                    Grid.Column="2"
                    Command="{Binding NextDayCommand}"
                    Text="&gt;"
                    BackgroundColor="Transparent"
                    TextColor="#FF6B35"
                    FontAttributes="Bold"
                    FontSize="18"
                    WidthRequest="36"
                    HeightRequest="36" />
            </Grid>
        </Frame>

        <!-- Loading indicator -->
        <ActivityIndicator
            Grid.Row="1"
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            Color="#FF6B35" />

        <!-- Sections list -->
        <ScrollView Grid.Row="2" Margin="16,0">
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Sections}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:MealSection">
                        <VerticalStackLayout Margin="0,0,0,16">

                            <!-- Section Header -->
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Margin="4,8,0,8"
                                Text="{Binding MealType}"
                                TextColor="#FF6B35" />

                            <!-- Meal cards -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Meals}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:MealPlan">
                                        <Frame
                                            Margin="0,0,0,8"
                                            Padding="12"
                                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                                            BorderColor="Transparent"
                                            CornerRadius="10">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference PlannerPageRoot}, Path=BindingContext.OpenRecipeCommand}"
                                                    CommandParameter="{Binding Recipe}" />
                                            </Frame.GestureRecognizers>

                                            <Grid ColumnDefinitions="56,*,Auto">

                                                <!-- Recipe image -->
                                                <Frame
                                                    Grid.Column="0"
                                                    Padding="0"
                                                    CornerRadius="8"
                                                    HeightRequest="56"
                                                    IsClippedToBounds="True"
                                                    WidthRequest="56">
                                                    <Image
                                                        Aspect="AspectFill"
                                                        HeightRequest="56"
                                                        Source="{Binding Recipe.ImageUrl}"
                                                        WidthRequest="56" />
                                                </Frame>

                                                <!-- Title + description -->
                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    VerticalOptions="Center">
                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="14"
                                                        Text="{Binding Recipe.Title}"
                                                        TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                                    <Label
                                                        FontSize="12"
                                                        MaxLines="2"
                                                        Text="{Binding Recipe.Description}"
                                                        TextColor="{AppThemeBinding Light=#888, Dark=#AAA}" />
                                                </VerticalStackLayout>

                                                <!-- Delete button -->
                                                <Button
                                                    Grid.Column="2"
                                                    Text="🗑"
                                                    BackgroundColor="Transparent"
                                                    FontSize="16"
                                                    VerticalOptions="Center"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    Command="{Binding Source={x:Reference PlannerPageRoot}, Path=BindingContext.DeleteMealCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Grid>
                                        </Frame>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>

        <!-- FAB -->
        <Button
            Grid.Row="2"
            BackgroundColor="#FF6B35"
            CornerRadius="28"
            FontSize="24"
            HeightRequest="56"
            HorizontalOptions="End"
            Margin="0,0,24,24"
            Text="+"
            TextColor="White"
            VerticalOptions="End"
            WidthRequest="56"
            Clicked="OnAddMealClicked" />

    </Grid>
</ContentPage>