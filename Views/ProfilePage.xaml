<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RecipesApp.ViewModels"
             x:Class="RecipesApp.Views.ProfilePage"
             x:DataType="vm:ProfilePageViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="*">
        <Border WidthRequest="320"
                HeightRequest="320"
                Margin="-120,-100,0,0"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Opacity="0.14"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 160">
            <Image Source="kitchen_tools.png" Aspect="AspectFill" />
        </Border>

        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid Padding="24,42,24,110">
                <VerticalStackLayout MaximumWidthRequest="520"
                                     HorizontalOptions="Center"
                                     Spacing="28">

                    <VerticalStackLayout Spacing="12"
                                         HorizontalOptions="Center">
                        <Border WidthRequest="96"
                                HeightRequest="96"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 48"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                            <Label Text="&#xE7FD;"
                                   FontFamily="MaterialIcons"
                                   FontSize="46"
                                   TextColor="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <Label Text="Chef Profile"
                               FontFamily="OpenSansSemibold"
                               FontAttributes="Bold,Italic"
                               FontSize="36"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Your account area is ready for Supabase user data."
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource Gray400}}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLowest}, Dark={StaticResource Gray900}}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.08" Radius="18" Offset="0,8" />
                        </Border.Shadow>
                        <VerticalStackLayout Padding="24" Spacing="16">

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                <Label Text="&#xE0E1;"
                                       FontFamily="MaterialIcons"
                                       FontSize="24"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       VerticalTextAlignment="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="Email"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="12"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" />
                                    <Label Text="{Binding Email}"
                                           FontSize="15"
                                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}" />
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                <Label Text="&#xE56C;"
                                       FontFamily="MaterialIcons"
                                       FontSize="24"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       VerticalTextAlignment="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="Preferences"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="12"
                                           CharacterSpacing="1.2"
                                           TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" />
                                    <Label Text="Editorial recipes, seasonal menus"
                                           FontSize="15"
                                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border HeightRequest="58"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 29"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Label Text="Log Out"
                                   FontFamily="OpenSansSemibold"
                                   FontAttributes="Bold"
                                   FontSize="17"
                                   TextColor="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}" />
                            <Label Text="&#xE9BA;"
                                   FontFamily="MaterialIcons"
                                   FontSize="22"
                                   TextColor="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}" />
                        </HorizontalStackLayout>
                    </Border>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       HorizontalOptions="Center" />

                    <Label Text="{Binding ErrorMessage}"
                           IsVisible="{Binding HasError}"
                           FontSize="13"
                           TextColor="#BA1A1A"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>