<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RecipesApp.ViewModels"
             x:Class="RecipesApp.Views.AddRecipePage"
             x:DataType="vm:AddRecipeViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Surface}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20,20,20,0">

        <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center" Margin="0,0,0,20">
            <Label Text="&#xE5CD;" FontFamily="MaterialIcons" FontSize="28" TextColor="{StaticResource Primary}" VerticalTextAlignment="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CancelCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <Label Grid.Column="1" Text="{Binding PageTitle}" FontFamily="OpenSansSemibold" FontAttributes="Bold,Italic" FontSize="22" TextColor="{StaticResource Primary}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />

            <Label Grid.Column="2" Text="DRAFT" FontFamily="OpenSansSemibold" FontSize="12" TextColor="{StaticResource Outline}" VerticalTextAlignment="Center" />
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="24" Padding="0,0,0,40">

                <Border HeightRequest="200" StrokeThickness="0" StrokeShape="RoundRectangle 16" BackgroundColor="{StaticResource SurfaceContainerHighest}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickImageCommand}" />
                    </Border.GestureRecognizers>
                    <Grid>
                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" Opacity="0.6"/>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                            <Label Text="&#xE412;" FontFamily="MaterialIcons" FontSize="36" TextColor="White" HorizontalOptions="Center" />
                            <Label Text="CHANGE COVER PHOTO" FontFamily="OpenSansSemibold" FontSize="12" TextColor="White" CharacterSpacing="1" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <VerticalStackLayout Spacing="8">
                    <Label Text="RECIPE TITLE" FontFamily="OpenSansSemibold" FontSize="11" CharacterSpacing="1.2" TextColor="{StaticResource Primary}" />
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceContainerHighest}">
                        <Entry Text="{Binding Title}" Placeholder="e.g. Roasted Thyme Salmon" FontSize="16" FontFamily="OpenSansSemibold" TextColor="{StaticResource OnSurface}" Margin="12,4" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="CATEGORY" FontFamily="OpenSansSemibold" FontSize="11" CharacterSpacing="1.2" TextColor="{StaticResource Primary}" />
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceContainerHighest}">
                        <Picker Title="Alege o categorie..."
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding Category}"
                                FontSize="14"
                                TextColor="{StaticResource OnSurface}"
                                TitleColor="{StaticResource Outline}"
                                Margin="12,4" />
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="TIMP PREPARARE (min)" FontFamily="OpenSansSemibold" FontSize="11" CharacterSpacing="1.2" TextColor="{StaticResource Primary}" />
                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceContainerHighest}">
                            <Entry Text="{Binding PrepTimeText}" Keyboard="Numeric" Placeholder="ex: 30" FontSize="14" TextColor="{StaticResource OnSurface}" Margin="12,4" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="CALORII (kcal)" FontFamily="OpenSansSemibold" FontSize="11" CharacterSpacing="1.2" TextColor="{StaticResource Primary}" />
                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceContainerHighest}">
                            <Entry Text="{Binding CaloriesText}" Keyboard="Numeric" Placeholder="ex: 450" FontSize="14" TextColor="{StaticResource OnSurface}" Margin="12,4" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="8">
                    <Label Text="THE INGREDIENTS" FontFamily="OpenSansSemibold" FontSize="11" CharacterSpacing="1.2" TextColor="{StaticResource Primary}" />
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceContainerHighest}">
                        <Editor Text="{Binding Ingredients}" Placeholder="List your ingredients here..." FontSize="14" TextColor="{StaticResource OnSurface}" HeightRequest="100" Margin="12,4" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="METHOD &amp; NARRATIVE" FontFamily="OpenSansSemibold" FontSize="11" CharacterSpacing="1.2" TextColor="{StaticResource Primary}" />
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource SurfaceContainerLowest}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.05" Radius="10" Offset="0,4" />
                        </Border.Shadow>
                        <Editor Text="{Binding Description}" Placeholder="Write the preparation steps..." FontSize="14" TextColor="{StaticResource OnSurfaceVariant}" HeightRequest="150" Margin="16,8" />
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2" ColumnDefinitions="*, 2*" ColumnSpacing="16" Padding="0,16,0,24" BackgroundColor="{StaticResource Surface}">
            <Button Text="CANCEL" BackgroundColor="Transparent" TextColor="{StaticResource Outline}" FontFamily="OpenSansSemibold" FontSize="13" Command="{Binding CancelCommand}" />
            <Button Grid.Column="1" Text="PUBLISH RECIPE" BackgroundColor="{StaticResource Primary}" TextColor="White" FontFamily="OpenSansSemibold" FontSize="13" CornerRadius="24" Command="{Binding SaveRecipeCommand}" />
        </Grid>

    </Grid>
</ContentPage>