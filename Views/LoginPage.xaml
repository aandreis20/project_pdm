<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RecipesApp.ViewModels"
             x:Class="RecipesApp.Views.LoginPage"
             x:DataType="vm:LoginPageViewModel"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Surface}">

    <Grid RowDefinitions="*">
        <Border WidthRequest="360"
                HeightRequest="360"
                Margin="0,-130,-120,0"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Opacity="0.13"
                Rotation="12"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 180">
            <Image Source="kitchen_herbs.png" Aspect="AspectFill" />
        </Border>

        <Border WidthRequest="300"
                HeightRequest="300"
                Margin="-100,0,0,-70"
                HorizontalOptions="Start"
                VerticalOptions="End"
                Opacity="0.14"
                Rotation="-7"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 150">
            <Image Source="kitchen_tools.png" Aspect="AspectFill" />
        </Border>

        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid Padding="28,44,28,96"
                  MinimumHeightRequest="760">
                <VerticalStackLayout Spacing="0"
                                     MaximumWidthRequest="480"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <VerticalStackLayout Spacing="12"
                                         HorizontalOptions="Center"
                                         Margin="0,0,0,48">
                        <Border WidthRequest="72"
                                HeightRequest="72"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                HorizontalOptions="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource Primary}" Offset="0" />
                                    <GradientStop Color="{StaticResource PrimaryContainer}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource Primary}" Opacity="0.22" Radius="18" Offset="0,8" />
                            </Border.Shadow>
                            <Label Text="&#xE56C;"
                                   FontFamily="MaterialIcons"
                                   FontSize="38"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <Label Text="The Editorial Kitchen"
                               FontFamily="OpenSansSemibold"
                               FontAttributes="Bold,Italic"
                               FontSize="28"
                               TextColor="{StaticResource Primary}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4"
                                         HorizontalOptions="Center"
                                         Margin="0,0,0,34">
                        <Label Text="Welcome Back"
                               FontFamily="OpenSansSemibold"
                               FontSize="42"
                               FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Sign in to continue your culinary journey"
                               FontSize="14"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="18">
                        <VerticalStackLayout Spacing="7">
                            <Label Text="EMAIL ADDRESS"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="11"
                                   CharacterSpacing="1.4"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   Margin="4,0,0,0" />

                            <Border HeightRequest="58"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource SurfaceContainerHighest}">
                                <Grid ColumnDefinitions="42,*"
                                      Padding="14,0,14,0">
                                    <Label Grid.Column="0"
                                           Text="&#xE0E1;"
                                           FontFamily="MaterialIcons"
                                           FontSize="22"
                                           TextColor="{StaticResource Outline}"
                                           HorizontalOptions="Start"
                                           VerticalOptions="Center" />
                                    <Entry Grid.Column="1"
                                           Text="{Binding Email}"
                                           Placeholder="chef@editorialkitchen.com"
                                           Keyboard="Email"
                                           ReturnType="Next"
                                           FontSize="14"
                                           TextColor="{StaticResource OnSurface}"
                                           PlaceholderColor="{StaticResource Outline}" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Grid ColumnDefinitions="*,Auto"
                                  Margin="4,0,4,0">
                                <Label Text="PASSWORD"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="11"
                                       CharacterSpacing="1.4"
                                       TextColor="{StaticResource OnSurfaceVariant}" />
                                <Label Grid.Column="1"
                                       Text="Forgot Password?"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="12"
                                       TextColor="{StaticResource Primary}" />
                            </Grid>

                            <Border HeightRequest="58"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource SurfaceContainerHighest}">
                                <Grid ColumnDefinitions="42,*,32"
                                      Padding="14,0,14,0">
                                    <Label Grid.Column="0"
                                           Text="&#xE897;"
                                           FontFamily="MaterialIcons"
                                           FontSize="22"
                                           TextColor="{StaticResource Outline}"
                                           HorizontalOptions="Start"
                                           VerticalOptions="Center" />
                                    <Entry Grid.Column="1"
                                           Text="{Binding Password}"
                                           Placeholder="Password"
                                           IsPassword="True"
                                           FontSize="14"
                                           TextColor="{StaticResource OnSurface}"
                                           PlaceholderColor="{StaticResource Outline}" />
                                    <Label Grid.Column="2"
                                           Text="&#xE8F4;"
                                           FontFamily="MaterialIcons"
                                           FontSize="22"
                                           TextColor="{StaticResource Outline}"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <Border HeightRequest="58"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 29"
                                Margin="0,10,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource Primary}" Offset="0" />
                                    <GradientStop Color="{StaticResource PrimaryContainer}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SignInCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="8"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <Label Text="Sign In"
                                       FontFamily="OpenSansSemibold"
                                       FontAttributes="Bold"
                                       FontSize="17"
                                       TextColor="White"
                                       VerticalTextAlignment="Center" />
                                <Label Text="&#xE5C8;"
                                       FontFamily="MaterialIcons"
                                       FontSize="22"
                                       TextColor="White"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HorizontalOptions="Center" />

                        <Label Text="{Binding ErrorMessage}"
                               IsVisible="{Binding HasError}"
                               FontSize="13"
                               TextColor="#BA1A1A"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto,*"
                          ColumnSpacing="14"
                          Margin="0,36,0,24"
                          VerticalOptions="Center">
                        <BoxView HeightRequest="1"
                                 Color="{StaticResource OutlineVariant}"
                                 Opacity="0.35"
                                 VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="OR CONNECT WITH"
                               FontFamily="OpenSansSemibold"
                               FontSize="11"
                               CharacterSpacing="1.3"
                               TextColor="{StaticResource Outline}" />
                        <BoxView Grid.Column="2"
                                 HeightRequest="1"
                                 Color="{StaticResource OutlineVariant}"
                                 Opacity="0.35"
                                 VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="14"
                          Margin="0,0,0,34">
                        <Border HeightRequest="50"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource SurfaceContainerLow}">
                            <HorizontalStackLayout Spacing="9"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <Image Source="google_mark.png" WidthRequest="20" HeightRequest="20" />
                                <Label Text="Google"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="14"
                                       TextColor="{StaticResource OnSurface}" />
                            </HorizontalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                HeightRequest="50"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource SurfaceContainerLow}">
                            <HorizontalStackLayout Spacing="9"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <Label Text="iOS"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="12"
                                       TextColor="{StaticResource OnSurface}" />
                                <Label Text="Apple"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="14"
                                       TextColor="{StaticResource OnSurface}" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <HorizontalStackLayout Spacing="5"
                                           HorizontalOptions="Center">
                        <Label Text="Don't have an account?"
                               FontSize="14"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                        <Label Text="Create New Account"
                               FontFamily="OpenSansSemibold"
                               FontAttributes="Bold"
                               FontSize="14"
                               TextColor="{StaticResource Primary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToSignUpCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
