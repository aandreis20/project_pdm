<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RecipesApp.ViewModels"
             xmlns:state="clr-namespace:RecipesApp.ViewModels.UIState"
             x:Class="RecipesApp.Views.RecipesPage"
             x:DataType="vm:RecipesPageViewModel"
             BackgroundColor="{StaticResource Surface}">

    <Grid RowDefinitions="*">
        <Border WidthRequest="320"
                HeightRequest="320"
                Margin="0,-120,-100,0"
                HorizontalOptions="End"
                VerticalOptions="Start"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 160"
                Opacity="0.12">
            <Image Source="toast_egg.png" Aspect="AspectFill" />
        </Border>

        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid Padding="24,28,24,96">
                <VerticalStackLayout MaximumWidthRequest="560"
                                     HorizontalOptions="Center"
                                     Spacing="24">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="18"
                          VerticalOptions="Center">
                        <Label Text="&#xE5D2;"
                               FontFamily="MaterialIcons"
                               FontSize="28"
                               TextColor="{StaticResource Primary}"
                               VerticalTextAlignment="Center" />

                        <Label Grid.Column="1"
                               Text="The Editorial&#10;Kitchen"
                               FontFamily="OpenSansSemibold"
                               FontAttributes="Bold,Italic"
                               FontSize="22"
                               LineHeight="1.05"
                               TextColor="{StaticResource Primary}" />

                        <Border Grid.Column="2"
                                WidthRequest="42"
                                HeightRequest="42"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 21"
                                BackgroundColor="{StaticResource InverseSurface}">
                            <Label Text="&#xE56C;"
                                   FontFamily="MaterialIcons"
                                   FontSize="20"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <Border HeightRequest="62"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 31"
                            BackgroundColor="{StaticResource SurfaceContainerHighest}">
                        <Grid ColumnDefinitions="34,*,34"
                              Padding="16,0">
                            <Label Text="&#xE8B6;"
                                   FontFamily="MaterialIcons"
                                   FontSize="22"
                                   TextColor="{StaticResource Outline}"
                                   VerticalTextAlignment="Center" />
                            <Label Grid.Column="1"
                                   Text="Search for recipes..."
                                   FontSize="14"
                                   TextColor="{StaticResource Outline}"
                                   VerticalTextAlignment="Center" />
                            <Label Grid.Column="2"
                                   Text="&#xE429;"
                                   FontFamily="MaterialIcons"
                                   FontSize="22"
                                   TextColor="{StaticResource Outline}"
                                   HorizontalTextAlignment="End"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>

                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="12">
                            <Border Padding="18,8"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource Primary}">
                                <Label Text="All"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="White" />
                            </Border>
                            <Border Padding="18,8"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource SurfaceContainerLow}">
                                <Label Text="Breakfast"
                                       FontSize="13"
                                       TextColor="{StaticResource OnSurface}" />
                            </Border>
                            <Border Padding="18,8"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource SurfaceContainerLow}">
                                <Label Text="Lunch"
                                       FontSize="13"
                                       TextColor="{StaticResource OnSurface}" />
                            </Border>
                            <Border Padding="18,8"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource SecondaryFixed}">
                                <Label Text="Dinner"
                                       FontSize="13"
                                       TextColor="{StaticResource SecondaryDarkText}" />
                            </Border>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <Label Text="Today's Inspirations"
                           FontFamily="OpenSansSemibold"
                           FontAttributes="Bold,Italic"
                           FontSize="28"
                           TextColor="{StaticResource OnSurface}"
                           Margin="0,8,0,0" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />

                    <Label Text="{Binding ErrorMessage}"
                           IsVisible="{Binding HasError}"
                           FontSize="13"
                           TextColor="#BA1A1A"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />

                    <CollectionView ItemsSource="{Binding Recipes}"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource SurfaceContainerLowest}">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Opacity="0.08" Radius="18" Offset="0,8" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="0">
                                    <Grid HeightRequest="240">
                                        <Image Source="toast_egg.png" Aspect="AspectFill" />
                                    </Grid>
                                    <VerticalStackLayout Padding="20,18,20,20"
                                                         Spacing="10">
                                        <Label Text="Recipes list"
                                               FontFamily="OpenSansSemibold"
                                               FontAttributes="Bold"
                                               FontSize="25"
                                               TextColor="{StaticResource OnSurface}" />
                                        <Label Text="Coming soon"
                                               FontFamily="OpenSansSemibold"
                                               FontAttributes="Bold,Italic"
                                               FontSize="34"
                                               TextColor="{StaticResource Primary}" />
                                        <Label Text="No recipes are visible for this user yet. Check rows and RLS policies in Supabase."
                                               FontSize="14"
                                               TextColor="{StaticResource OnSurfaceVariant}"
                                               LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="state:RecipeUi">
                                <Border Margin="0,0,0,24"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{StaticResource SurfaceContainerLowest}">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Opacity="0.08" Radius="18" Offset="0,8" />
                                    </Border.Shadow>
                                    <VerticalStackLayout Spacing="0">
                                        <Grid HeightRequest="240">
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                            <Border Padding="10,5"
                                                    Margin="12,0,0,12"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="End"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8"
                                                    BackgroundColor="{StaticResource Primary}">
                                                <Label Text="{Binding Category}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="11"
                                                       TextColor="White" />
                                            </Border>
                                        </Grid>
                                        <VerticalStackLayout Padding="20,18,20,20"
                                                             Spacing="9">
                                            <Label Text="{Binding Title}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontAttributes="Bold"
                                                   FontSize="24"
                                                   TextColor="{StaticResource OnSurface}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding Description}"
                                                   FontSize="14"
                                                   TextColor="{StaticResource OnSurfaceVariant}"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding Ingredients}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource Outline}"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid ColumnDefinitions="*,Auto"
                          Margin="0,8,0,0">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Planner, community and settings placeholders"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="15"
                                   TextColor="{StaticResource OnSurface}" />
                            <Label Text="The visual structure is ready for real recipe data."
                                   FontSize="13"
                                   TextColor="{StaticResource OnSurfaceVariant}" />
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                WidthRequest="58"
                                HeightRequest="58"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 29"
                                BackgroundColor="{StaticResource Primary}">
                            <Label Text="&#xE145;"
                                   FontFamily="MaterialIcons"
                                   FontSize="30"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
