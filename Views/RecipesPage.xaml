<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RecipesApp.ViewModels"
             xmlns:state="clr-namespace:RecipesApp.ViewModels.UIState"
             x:Class="RecipesApp.Views.RecipesPage"
             x:Name="RecipesPageRoot"
             x:DataType="vm:RecipesPageViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="*">
        <Border WidthRequest="320" HeightRequest="320" Margin="0,-120,-100,0" HorizontalOptions="End" VerticalOptions="Start" StrokeThickness="0" StrokeShape="RoundRectangle 160" Opacity="0.12">
            <Image Source="toast_egg.png" Aspect="AspectFill" />
        </Border>

        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid Padding="24,28,24,100">
                <VerticalStackLayout MaximumWidthRequest="560" HorizontalOptions="Center" Spacing="24">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="18" VerticalOptions="Center">
                        <Label Text="&#xE5D2;" FontFamily="MaterialIcons" FontSize="28" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToSettingsCommand}" />
                            </Label.GestureRecognizers>
                        </Label>

                        <Label Grid.Column="1" Text="The Editorial&#10;Kitchen" FontFamily="OpenSansSemibold" FontAttributes="Bold,Italic" FontSize="22" LineHeight="1.05" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                        <Border Grid.Column="2" WidthRequest="42" HeightRequest="42" StrokeThickness="0" StrokeShape="RoundRectangle 21" BackgroundColor="{AppThemeBinding Light={StaticResource InverseSurface}, Dark={StaticResource SurfaceContainerHighest}}">
                            <Label Text="&#xE56C;" FontFamily="MaterialIcons" FontSize="20" TextColor="{AppThemeBinding Light=White, Dark={StaticResource OffBlack}}" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="Inspirations"/>
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsShowingInspirations}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsShowingInspirations}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceContainerHighest}, Dark={StaticResource Gray900}}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Label Text="Inspirations" FontFamily="OpenSansSemibold" FontSize="13" HorizontalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsShowingInspirations}" Value="True">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsShowingInspirations}" Value="False">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>

                        <Border Grid.Column="1" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="AllRecipes"/>
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsShowingAllRecipes}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsShowingAllRecipes}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceContainerHighest}, Dark={StaticResource Gray900}}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Label Text="All recipes" FontFamily="OpenSansSemibold" FontSize="13" HorizontalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsShowingAllRecipes}" Value="True">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsShowingAllRecipes}" Value="False">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </Grid>

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" HorizontalOptions="Center" />
                    <Label Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" FontSize="13" TextColor="#BA1A1A" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />

                    <VerticalStackLayout IsVisible="{Binding IsShowingInspirations}" Spacing="16">
                        <Label Text="Ideas for today" FontFamily="OpenSansSemibold" FontAttributes="Bold,Italic" FontSize="24" TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}" Margin="0,8,0,0" />

                        <CollectionView ItemsSource="{Binding Recipes}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="state:RecipeUi">
                                    <Border Margin="0,0,0,24" StrokeThickness="0" StrokeShape="RoundRectangle 24" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLowest}, Dark={StaticResource Gray900}}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference RecipesPageRoot}, Path=BindingContext.OpenRecipeCommand}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Opacity="0.1" Radius="12" Offset="0,6" />
                                        </Border.Shadow>

                                        <VerticalStackLayout Spacing="0">
                                            <Grid HeightRequest="220">
                                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                                <Border HorizontalOptions="Start" VerticalOptions="End" Margin="16" Padding="10,6" StrokeThickness="0" StrokeShape="RoundRectangle 6" BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                                                    <Label Text="{Binding Category}" TextColor="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}" FontSize="10" FontFamily="OpenSansSemibold" TextTransform="Uppercase" />
                                                </Border>
                                            </Grid>
                                            <VerticalStackLayout Padding="20" Spacing="8">
                                                <Label Text="{Binding Title}" FontFamily="OpenSansSemibold" FontSize="20" TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}" LineBreakMode="TailTruncation" MaxLines="2" />
                                                <HorizontalStackLayout Spacing="16" Margin="0,4,0,0">
                                                    <HorizontalStackLayout Spacing="4">
                                                        <Label Text="&#xE192;" FontFamily="MaterialIcons" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                                                        <Label Text="{Binding PrepTime, StringFormat='{0} mins'}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                    <HorizontalStackLayout Spacing="4">
                                                        <Label Text="&#xE3E7;" FontFamily="MaterialIcons" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                                                        <Label Text="{Binding Calories, StringFormat='{0} kcal'}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding IsShowingAllRecipes}" Spacing="16">

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,0,0,10">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="CATEGORY" FontSize="11" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                <Border StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerHighest}, Dark={StaticResource Gray900}}">
                                    <Picker ItemsSource="{Binding FilterCategories}" SelectedItem="{Binding SelectedCategory}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}" TitleColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" Margin="8,0" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="SORT BY" FontSize="11" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                <Border StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerHighest}, Dark={StaticResource Gray900}}">
                                    <Picker ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}" TitleColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" Margin="8,0" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <CollectionView ItemsSource="{Binding DisplayedAllRecipes}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="state:RecipeUi">
                                    <Border Margin="0,0,0,24" StrokeThickness="0" StrokeShape="RoundRectangle 24" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLowest}, Dark={StaticResource Gray900}}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference RecipesPageRoot}, Path=BindingContext.OpenRecipeCommand}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Opacity="0.1" Radius="12" Offset="0,6" />
                                        </Border.Shadow>

                                        <VerticalStackLayout Spacing="0">
                                            <Grid HeightRequest="220">
                                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                                <Border HorizontalOptions="Start" VerticalOptions="End" Margin="16" Padding="10,6" StrokeThickness="0" StrokeShape="RoundRectangle 6" BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                                                    <Label Text="{Binding Category}" TextColor="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}" FontSize="10" FontFamily="OpenSansSemibold" TextTransform="Uppercase" />
                                                </Border>
                                            </Grid>
                                            <VerticalStackLayout Padding="20" Spacing="8">
                                                <Label Text="{Binding Title}" FontFamily="OpenSansSemibold" FontSize="20" TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}" LineBreakMode="TailTruncation" MaxLines="2" />
                                                <HorizontalStackLayout Spacing="16" Margin="0,4,0,0">
                                                    <HorizontalStackLayout Spacing="4">
                                                        <Label Text="&#xE192;" FontFamily="MaterialIcons" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                                                        <Label Text="{Binding PrepTime, StringFormat='{0} mins'}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                    <HorizontalStackLayout Spacing="4">
                                                        <Label Text="&#xE3E7;" FontFamily="MaterialIcons" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                                                        <Label Text="{Binding Calories, StringFormat='{0} kcal'}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}" VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Grid>
        </ScrollView>

        <Border WidthRequest="64" HeightRequest="64" Margin="24,0,24,24" HorizontalOptions="End" VerticalOptions="End" StrokeThickness="0" StrokeShape="RoundRectangle 32" BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.25" Radius="12" Offset="0,6" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAddRecipeClicked" />
            </Border.GestureRecognizers>
            <Label Text="&#xE145;" FontFamily="MaterialIcons" FontSize="32" TextColor="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}" HorizontalOptions="Center" VerticalOptions="Center" />
        </Border>

    </Grid>
</ContentPage>