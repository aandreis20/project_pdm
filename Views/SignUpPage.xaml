<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RecipesApp.ViewModels"
             x:Class="RecipesApp.Views.SignUpPage"
             x:DataType="vm:SignUpPageViewModel"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="*">
        <Border WidthRequest="340"
                HeightRequest="340"
                Margin="0,-130,-120,0"
                HorizontalOptions="End"
                VerticalOptions="Start"
                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryFixed}, Dark={StaticResource PrimaryDark}}"
                Opacity="0.18"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 170" />

        <Border WidthRequest="380"
                HeightRequest="380"
                Margin="-180,0,0,0"
                HorizontalOptions="Start"
                VerticalOptions="Center"
                BackgroundColor="{AppThemeBinding Light={StaticResource SecondaryFixed}, Dark={StaticResource Tertiary}}"
                Opacity="0.16"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 190" />

        <Border WidthRequest="190"
                HeightRequest="190"
                Margin="0,0,-48,-40"
                HorizontalOptions="End"
                VerticalOptions="End"
                Opacity="0.72"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 95">
            <Image Source="salad_bowl.png" Aspect="AspectFill" />
        </Border>

        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid Padding="28,40,28,100" MinimumHeightRequest="760">
                <VerticalStackLayout Spacing="0"
                                     MaximumWidthRequest="520"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">

                    <VerticalStackLayout Spacing="18"
                                         HorizontalOptions="Center"
                                         Margin="0,0,0,34">
                        <Border WidthRequest="96"
                                HeightRequest="96"
                                Rotation="-3"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14">
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.16" Radius="16" Offset="0,8" />
                            </Border.Shadow>
                            <Image Source="kitchen_herbs.png" Aspect="AspectFill" />
                        </Border>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Join our Kitchen"
                                   FontFamily="OpenSansSemibold"
                                   FontAttributes="Bold,Italic"
                                   FontSize="40"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Create your account to start your culinary journey."
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource Gray400}}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="18">

                        <VerticalStackLayout Spacing="7">
                            <Label Text="FULL NAME"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="11"
                                   CharacterSpacing="1.4"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   Margin="4,0,0,0" />
                            <Border HeightRequest="58"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerHighest}, Dark={StaticResource Gray900}}">
                                <Entry Text="{Binding FullName}"
                                       Placeholder="Alice Waters"
                                       FontSize="14"
                                       Margin="15,0"
                                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}"
                                       PlaceholderColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray600}}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="7">
                            <Label Text="EMAIL ADDRESS"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="11"
                                   CharacterSpacing="1.4"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   Margin="4,0,0,0" />
                            <Border HeightRequest="58"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerHighest}, Dark={StaticResource Gray900}}">
                                <Entry Text="{Binding Email}"
                                       Placeholder="alice@editorialkitchen.com"
                                       Keyboard="Email"
                                       FontSize="14"
                                       Margin="15,0"
                                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}"
                                       PlaceholderColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray600}}" />
                            </Border>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <VerticalStackLayout Spacing="7">
                                <Label Text="PASSWORD"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="11"
                                       CharacterSpacing="1.4"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       Margin="4,0,0,0" />
                                <Border HeightRequest="58"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerHighest}, Dark={StaticResource Gray900}}">
                                    <Entry Text="{Binding Password}"
                                           Placeholder="Password"
                                           IsPassword="True"
                                           FontSize="14"
                                           Margin="15,0"
                                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}"
                                           PlaceholderColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray600}}" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="7">
                                <Label Text="CONFIRM"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="11"
                                       CharacterSpacing="1.4"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       Margin="4,0,0,0" />
                                <Border HeightRequest="58"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerHighest}, Dark={StaticResource Gray900}}">
                                    <Entry Text="{Binding ConfirmPassword}"
                                           Placeholder="Confirm"
                                           IsPassword="True"
                                           FontSize="14"
                                           Margin="15,0"
                                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}"
                                           PlaceholderColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray600}}" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Border HeightRequest="62"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 31"
                                Margin="0,8,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" Offset="0" />
                                    <GradientStop Color="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource Primary}}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" Opacity="0.18" Radius="18" Offset="0,8" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SignUpCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="8"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <Label Text="Sign Up"
                                       FontFamily="OpenSansSemibold"
                                       FontAttributes="Bold"
                                       FontSize="17"
                                       TextColor="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}" />
                                <Label Text="&#xE5C8;"
                                       FontFamily="MaterialIcons"
                                       FontSize="22"
                                       TextColor="{AppThemeBinding Light=White, Dark={StaticResource PrimaryDarkText}}" />
                            </HorizontalStackLayout>
                        </Border>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                           HorizontalOptions="Center" />

                        <Label Text="{Binding ErrorMessage}"
                               IsVisible="{Binding HasError}"
                               FontSize="13"
                               TextColor="#BA1A1A"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />

                        <Label Text="{Binding InfoMessage}"
                               IsVisible="{Binding HasInfo}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Spacing="5"
                                           Margin="0,34,0,0"
                                           HorizontalOptions="Center">
                        <Label Text="Already have an account?"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource Gray400}}" />
                        <Label Text="Sign In"
                               FontFamily="OpenSansSemibold"
                               FontAttributes="Bold"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>