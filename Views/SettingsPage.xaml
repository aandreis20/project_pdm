<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:RecipesApp.ViewModels"
             x:Class="RecipesApp.Views.SettingsPage"
             Title="Settings"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout Padding="16,24" Spacing="24">

            <Label Text="Settings" 
                   FontAttributes="Bold" 
                   FontSize="32" 
                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}" 
                   Margin="8,0,0,8"/>

            <VerticalStackLayout Spacing="8">
                <Label Text="PERSONALIZATION" 
                       FontAttributes="Bold" 
                       FontSize="12" 
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource Gray400}}" 
                       CharacterSpacing="1.2" 
                       Margin="8,0,0,0"/>

                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLowest}, Dark={StaticResource Gray900}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                    </Border.Shadow>

                    <Grid Padding="16,12" ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ChangeThemeCommand}" />
                        </Grid.GestureRecognizers>

                        <Border Grid.Column="0" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#FFEBE0" WidthRequest="40" HeightRequest="40" VerticalOptions="Center">
                            <Label Text="&#xE3A9;" FontFamily="MaterialIcons" TextColor="#B25900" HorizontalOptions="Center" VerticalOptions="Center" FontSize="20"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="16,0,0,0">
                            <Label Text="App Theme" FontAttributes="Bold" FontSize="16"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}"/>
                            <Label Text="{Binding ThemeText}" FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource Gray400}}"/>
                        </VerticalStackLayout>

                        <Label Grid.Column="2" Text="&#xE5CC;" FontFamily="MaterialIcons" FontSize="24" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource Gray600}}"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="APPLICATION" 
                       FontAttributes="Bold" 
                       FontSize="12" 
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource Gray400}}" 
                       CharacterSpacing="1.2" 
                       Margin="8,0,0,0"/>

                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLowest}, Dark={StaticResource Gray900}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                    </Border.Shadow>

                    <VerticalStackLayout>
                        <Grid Padding="16,16" ColumnDefinitions="Auto, *">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding AboutCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="&#xE88E;" FontFamily="MaterialIcons" FontSize="24" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}"/>

                            <Label Grid.Column="1" Text="About Editorial Kitchen" FontSize="16" VerticalOptions="Center" Margin="16,0,0,0"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}"/>
                        </Grid>

                        <BoxView HeightRequest="1" Margin="56,0,0,0" 
                                 Color="{AppThemeBinding Light={StaticResource SurfaceContainerHigh}, Dark={StaticResource Gray600}}" />

                        <Grid Padding="16,16" ColumnDefinitions="Auto, *">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TermsCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="&#xE873;" FontFamily="MaterialIcons" FontSize="24" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource Gray400}}"/>

                            <Label Grid.Column="1" Text="Terms of Service" FontSize="16" VerticalOptions="Center" Margin="16,0,0,0"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource Surface}}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>