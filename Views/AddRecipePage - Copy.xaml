<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:YourApp.ViewModels"
             x:Class="YourApp.Views.SettingsPage"
             Title="Settings">

    <VerticalStackLayout Padding="20" Spacing="20">

        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
            <Label Text="Vegetarian Only" VerticalOptions="Center" />
            <Switch IsToggled="{Binding IsVegetarian}" />
        </HorizontalStackLayout>

        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
            <Label Text="Dark Theme" VerticalOptions="Center" />
            <Switch IsToggled="{Binding IsDarkTheme}" />
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>